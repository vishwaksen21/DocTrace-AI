# ─────────────────────────────────────────────────────────────────────────────
# DocTrace AI — Environment Variables
#
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────

APP_NAME="DocTrace AI"

# One of: development | staging | production
# Controls: log format (JSON in production), docs UI visibility, debug features
ENVIRONMENT=development

# Enable verbose output and SQL echo (development only)
DEBUG=false

# Minimum log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ── PostgreSQL ────────────────────────────────────────────────────────────────
#
# For Docker Compose:       postgresql+asyncpg://doctrace:doctrace@localhost:5432/doctrace_db
# For production (Neon):    postgresql+asyncpg://user:pass@host/dbname?ssl=require

DATABASE_URL=postgresql+asyncpg://doctrace:doctrace@localhost:5432/doctrace_db

# SQLAlchemy connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Log every SQL statement (very noisy — enable only for SQL debugging)
DATABASE_ECHO_SQL=false


# ── MongoDB ───────────────────────────────────────────────────────────────────
#
# For Docker Compose:   mongodb://localhost:27017
# For Atlas:            mongodb+srv://user:pass@cluster.mongodb.net/

MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE_NAME=doctrace_ai


# ── LLM Provider (OpenAI-compatible API) ─────────────────────────────────────
#
# DocTrace AI uses an OpenAI-compatible HTTP API so you can switch providers
# by changing OPENROUTER_BASE_URL and LLM_MODEL without any code changes.
#
# ┌──────────────┬──────────────────────────────────────────────┬────────────────────────────────┐
# │ Provider     │ OPENROUTER_BASE_URL                          │ LLM_MODEL example              │
# ├──────────────┼──────────────────────────────────────────────┼────────────────────────────────┤
# │ OpenRouter   │ https://openrouter.ai/api/v1                 │ google/gemini-2.5-flash         │
# │ OpenAI       │ https://api.openai.com/v1                    │ gpt-4o-mini                    │
# │ Groq         │ https://api.groq.com/openai/v1               │ llama-3.1-70b-versatile        │
# │ Gemini       │ https://generativelanguage.googleapis.com/   │ gemini-2.5-flash               │
# │              │   v1beta/openai/                             │                                │
# └──────────────┴──────────────────────────────────────────────┴────────────────────────────────┘
#
# Get an OpenRouter key at: https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash

# Timeout for a single LLM API call (seconds)
LLM_TIMEOUT_SECONDS=60.0

# Retry attempts on transient errors (network timeout, 429 rate limit, 5xx)
LLM_MAX_RETRIES=3

# Exponential backoff bounds (seconds)
LLM_RETRY_MIN_WAIT_SECONDS=1.0
LLM_RETRY_MAX_WAIT_SECONDS=30.0


# ── File Upload ───────────────────────────────────────────────────────────────

# Maximum PDF upload size in megabytes
MAX_UPLOAD_SIZE_MB=50


# ── Pagination ────────────────────────────────────────────────────────────────

DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
