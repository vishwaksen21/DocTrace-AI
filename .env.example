# ─────────────────────────────────────────────────────────────────────────────
# DocTrace AI — Environment Variables
#
# Copy this file:   cp .env.example .env
# Fill in:          OPENROUTER_API_KEY (required for LLM features)
#                   SECRET_KEY (required for JWT auth in production)
#                   REDIS_URL (optional - enables distributed rate limiting)
# Start locally:    uvicorn app.main:app --reload
# Start via Docker: docker compose up
#
# NEVER commit .env to version control — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────

APP_NAME="DocTrace AI"

# development | staging | production
# Controls: log format (JSON in production), Swagger UI visibility
ENVIRONMENT=development

DEBUG=false
LOG_LEVEL=INFO


# ── Authentication (JWT) ──────────────────────────────────────────────────────
#
# Generate a strong secret:  openssl rand -hex 32
# MUST be set in production (min 32 chars)
SECRET_KEY=dev-secret-change-in-production-min-32-chars

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


# ── Database ──────────────────────────────────────────────────────────────────
#
# SQLite (default — zero external dependencies, works locally out of the box):
DATABASE_URL=sqlite+aiosqlite:///./data/doctrace.db

# PostgreSQL (for production — swap this URL and no code changes needed):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/doctrace_db

# Set to true to log all SQL statements (very noisy — debugging only)
DATABASE_ECHO_SQL=false


# ── MongoDB ───────────────────────────────────────────────────────────────────
#
# Run locally:   brew install mongodb-community && brew services start mongodb-community
# Or via Docker: docker compose up mongodb
# Or Atlas:      mongodb+srv://user:pass@cluster.mongodb.net/

MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE_NAME=doctrace_ai


# ── Redis (optional — enables distributed rate limiting & token blacklist) ────
#
# Run locally:   brew install redis && brew services start redis
# Or via Docker: docker compose up redis
#
# If not set, rate limiting uses in-memory store (single-instance only)
REDIS_URL=redis://localhost:6379/0


# ── LLM Provider (OpenAI-compatible API) ─────────────────────────────────────
#
# Switch providers by changing the two variables below — zero code changes.
#
# ┌──────────────┬──────────────────────────────────────────┬────────────────────────┐
# │ Provider     │ OPENROUTER_BASE_URL                      │ LLM_MODEL              │
# ├──────────────┼──────────────────────────────────────────┼────────────────────────┤
# │ OpenRouter   │ https://openrouter.ai/api/v1             │ google/gemini-2.5-flash │
# │ OpenAI       │ https://api.openai.com/v1                │ gpt-4o-mini            │
# │ Groq         │ https://api.groq.com/openai/v1           │ llama-3.1-70b-versatile│
# │ Gemini       │ https://generativelanguage.googleapis.com│ gemini-2.5-flash       │
# │              │   /v1beta/openai/                        │                        │
# └──────────────┴──────────────────────────────────────────┴────────────────────────┘
#
# Get an OpenRouter key: https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash

LLM_TIMEOUT_SECONDS=60.0
LLM_MAX_RETRIES=3
LLM_RETRY_MIN_WAIT_SECONDS=1.0
LLM_RETRY_MAX_WAIT_SECONDS=30.0


# ── File Upload ───────────────────────────────────────────────────────────────

MAX_UPLOAD_SIZE_MB=50


# ── Pagination ────────────────────────────────────────────────────────────────

DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100


# ── Observability (M13) ──────────────────────────────────────────────────────

# Enable OpenTelemetry tracing (requires OTLP collector)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=doctrace-ai
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_INSECURE=true

# Prometheus metrics endpoint (always enabled)
METRICS_ENABLED=true
METRICS_PATH=/metrics